# --- AI Engine ---
OPENAI_API_KEY=your-api-key-here
OPENAI_BASE_URL=https://opencode.ai/zen/go/v1
OPENAI_MODEL=kimi-k2.5

# --- Agent Behavior ---
AGENT_MAX_ITERATIONS=10
AGENT_TEMPERATURE=0.3
AGENT_CHAT_HISTORY_LIMIT=30
SYSTEM_PROMPT_PATH=backend/prompts/system_prompt.md
MAX_MESSAGE_LENGTH=4000

# --- Database ---
# For SQLite (default):
DATABASE_PATH=data/stocks_agent.db
# For PostgreSQL (overrides SQLite when set):
# DATABASE_URL=postgresql://user:password@localhost:5432/stocksagent
CHAT_HISTORY_DEFAULT_LIMIT=50

# --- Yahoo Finance / Cache ---
CACHE_QUOTE_TTL=60
CACHE_QUOTE_MAXSIZE=200
CACHE_INFO_TTL=3600
CACHE_INFO_MAXSIZE=100
CACHE_FINANCIALS_TTL=3600
CACHE_FINANCIALS_MAXSIZE=100
YAHOO_MAX_RETRIES=3
YAHOO_RETRY_DELAY=2
MAX_COMPARE_STOCKS=10

# --- Flask ---
FLASK_HOST=0.0.0.0
FLASK_PORT=5001
FLASK_DEBUG=true
CORS_ORIGINS=*
